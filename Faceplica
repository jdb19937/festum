# Faceplica — aedificatio festum
#
# Usus:
#   face            — aedifica festum
#   face purga      — dele omnia aedificata
#   face colloca    — colloca in /opt/apotheca/bin

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2

omnia: festum

festum: festum.c
	$(CC) $(CFLAGS) -o $@ $<

PREFIX = /opt/apotheca

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 festum $(PREFIX)/bin/

purga:
	rm -f festum

linte:
	insinulint -c festum.c

.PHONY: omnia colloca purga linte
